-- 1. Total Revenue and Order Count by Product Category
SELECT 
    category_name,
    COUNT(order_id) AS total_orders,
    SUM(order_amount) AS total_revenue
FROM sales_data
GROUP BY category_name
ORDER BY total_revenue DESC;

-- 2. Customer RFM Segmentation (Recency, Frequency, Monetary)
WITH Customer_RFM AS (
    SELECT 
        customer_id,
        DATEDIFF('2026-07-01', MAX(order_date)) AS Recency,
        COUNT(order_id) AS Frequency,
        SUM(order_amount) AS Monetary
    FROM sales_data
    GROUP BY customer_id
)
SELECT 
    customer_id,
    Recency,
    Frequency,
    Monetary,
    CASE 
        WHEN Recency <= 30 AND Frequency >= 5 THEN 'VIP Customer'
        WHEN Recency <= 60 AND Frequency >= 2 THEN 'Loyal Customer'
        ELSE 'At-Risk Customer'
    END AS Customer_Segment
FROM Customer_RFM;
